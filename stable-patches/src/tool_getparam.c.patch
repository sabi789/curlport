diff --git a/src/tool_getparam.c b/src/tool_getparam.c
index 841c6ff..cd64788 100644
--- a/src/tool_getparam.c
+++ b/src/tool_getparam.c
@@ -23,6 +23,11 @@
  ***************************************************************************/
 #include "tool_setup.h"
 
+#ifdef __MVS__
+#include <zos.h>
+#include <_Ccsid.h>
+#endif
+
 #include "tool_cfgable.h"
 #include "tool_cb_prg.h"
 #include "tool_filetime.h"
@@ -123,6 +128,7 @@ static const struct LongShort aliases[]= {
   {"dns-ipv4-addr",              ARG_STRG, ' ', C_DNS_IPV4_ADDR},
   {"dns-ipv6-addr",              ARG_STRG, ' ', C_DNS_IPV6_ADDR},
   {"dns-servers",                ARG_STRG, ' ', C_DNS_SERVERS},
+  {"download-encoding",          ARG_STRG, ' ', C_DOWNLOAD_ENCODING},
   {"doh-cert-status",            ARG_BOOL|ARG_TLS, ' ', C_DOH_CERT_STATUS},
   {"doh-insecure",               ARG_BOOL|ARG_TLS, ' ', C_DOH_INSECURE},
   {"doh-url"        ,            ARG_STRG, ' ', C_DOH_URL},
@@ -328,6 +334,7 @@ static const struct LongShort aliases[]= {
   {"stderr",                     ARG_FILE, ' ', C_STDERR},
   {"styled-output",              ARG_BOOL, ' ', C_STYLED_OUTPUT},
   {"suppress-connect-headers",   ARG_BOOL, ' ', C_SUPPRESS_CONNECT_HEADERS},
+  {"tag",                        ARG_STRG, ' ', C_DOWNLOAD_ENCODING}, /* alias */
   {"tcp-fastopen",               ARG_BOOL, ' ', C_TCP_FASTOPEN},
   {"tcp-nodelay",                ARG_BOOL, ' ', C_TCP_NODELAY},
   {"telnet-option",              ARG_STRG, 't', C_TELNET_OPTION},
@@ -356,6 +363,7 @@ static const struct LongShort aliases[]= {
   {"trace-ids",                  ARG_BOOL, ' ', C_TRACE_IDS},
   {"trace-time",                 ARG_BOOL, ' ', C_TRACE_TIME},
   {"unix-socket",                ARG_FILE, ' ', C_UNIX_SOCKET},
+  {"upload-encoding",            ARG_STRG, ' ', C_UPLOAD_ENCODING},
   {"upload-file",                ARG_FILE, 'T', C_UPLOAD_FILE},
   {"upload-flags",               ARG_STRG, ' ', C_UPLOAD_FLAGS},
   {"url",                        ARG_STRG, ' ', C_URL},
@@ -2835,6 +2843,42 @@ static ParameterError opt_string(struct OperationConfig *config,
   case C_UPLOAD_FLAGS: /* --upload-flags */
     err = parse_upload_flags(config, nextarg);
     break;
+  case C_UPLOAD_ENCODING: /* --upload-encoding */
+    /* For datasets, store in upload_encoding for backward compatibility */
+    /* For z/OS UNIX files, store in upload_encoding_unix */
+    err = getstr(&config->upload_encoding, nextarg, DENY_BLANK);
+    if(!err)
+      err = getstr(&config->upload_encoding_unix, nextarg, DENY_BLANK);
+    break;
+  case C_DOWNLOAD_ENCODING: /* --download-encoding (and --tag alias) */
+#ifdef __MVS__
+    /* Store the encoding string for later processing */
+    err = getstr(&config->download_encoding, nextarg, DENY_BLANK);
+    if(!err) {
+      /* Also set local_ccsid for backward compatibility */
+      if(!strcasecmp(nextarg, "auto"))
+        config->local_ccsid = 0;
+      else if(!strcasecmp(nextarg, "binary"))
+        config->local_ccsid = 65535;
+      else if(!strcasecmp(nextarg, "ascii") || 
+              !strcasecmp(nextarg, "e2a"))
+        config->local_ccsid = 819;  /* ISO 8859-1 (ASCII-compatible) */
+      else if(!strcasecmp(nextarg, "a2e"))
+        config->local_ccsid = 1047; /* IBM EBCDIC */
+      else {
+        unsigned short ccsid = __toCcsid((char*)nextarg);
+        if(ccsid == 0) {
+          warnf("Invalid --download-encoding value: %s", nextarg);
+          err = PARAM_BAD_USE;
+        } else {
+          config->local_ccsid = ccsid;
+        }
+      }
+    }
+#else
+    warnf("--download-encoding is ignored on this platform");
+#endif
+    break;
   }
   return err;
 }
