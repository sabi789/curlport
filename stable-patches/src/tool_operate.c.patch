+#ifdef __MVS__
+    /* z/OS: Check if this is a dataset (starts with //) */
+    if(is_dataset(per->uploadfile)) {
+      /* Use fopen for z/OS datasets with record mode */
+      per->infp = fopen(per->uploadfile, "rb,type=record");
