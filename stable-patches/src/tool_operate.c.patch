+#ifdef __MVS__
+/* Check if filename is a z/OS dataset (starts with //) */
+static int is_dataset(const char *filename)
+{
+  if(filename == NULL || strlen(filename) < 2)
+    return 0;
+  
+  return (filename[0] == '/' && filename[1] == '/');
+}
+#endif
